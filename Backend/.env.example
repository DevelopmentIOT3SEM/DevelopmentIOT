# Copie este arquivo para `.env` (que é ignorado pelo Git) e ajuste os valores.
# O docker-compose lê estas variáveis automaticamente.

# --- Banco de dados (PostgreSQL) ---
POSTGRES_USER=admin
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_DB=pecasdb

# --- pgAdmin ---
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=troque-esta-senha

# --- API (.NET) ---
# Gere uma chave forte e única (>= 32 caracteres). Exemplos:
#   openssl rand -base64 48
#   pwsh -c "[Convert]::ToBase64String((1..48|%{Get-Random -Max 256}))"
JWT_SECRET=COLOQUE_UMA_CHAVE_FORTE_E_UNICA_AQUI

# Origem do front-end (CORS). Ajuste para a URL do site quando publicar.
WEB_ORIGIN=http://localhost:5173
