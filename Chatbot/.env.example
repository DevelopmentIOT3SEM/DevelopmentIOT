# Copie para `.env` (ignorado pelo Git) e ajuste conforme seu ambiente.

# URL base da API .NET. Local: http://localhost:5271/api
# Em Docker (mesma rede do compose): http://backend:8080/api
API_BASE_URL=http://localhost:5271/api

# Timeout (segundos) das chamadas à API.
REQUEST_TIMEOUT=5

# Servidor Flask (dev). Em produção use Gunicorn (ver README).
HOST=0.0.0.0
PORT=5000
FLASK_DEBUG=0

# CORS: "*" ou origens separadas por vírgula (ex.: http://localhost:5173).
CORS_ORIGINS=*
