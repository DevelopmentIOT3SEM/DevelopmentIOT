# Copie para `.env` (ignorado pelo Git) e ajuste conforme seu ambiente.
# URL da API .NET. Em emulador Android use http://10.0.2.2:5271;
# em dispositivo físico, o IP da sua máquina na rede (ex.: http://192.168.0.10:5271).
EXPO_PUBLIC_API_URL=http://localhost:5271

# URL do serviço de chatbot (Flask).
EXPO_PUBLIC_CHATBOT_URL=http://localhost:5000
